## Detalhamento por Fase

### Fase 1 - Modelos de Dados

#### [MODIFY] [types.ts](file:///c:/Users/i5/Downloads/Cesta%20Basica%20na%20sua%20Casa/types.ts)

Novos tipos a adicionar:

```typescript
// Modelo de Cesta (Pequena, Grande, Big, Short...)
export interface BasketModel {
  id: string;
  name: string;
  description: string;
  price: number;
  weight: string;
  image: string;
  active: boolean;
}

// Entrada de Estoque
export interface StockEntry {
  id: string;
  basketModelId: string;
  quantity: number;
  unitCost: number;
  supplier: string;
  receivedAt: number;
  createdBy: string;
}

// Cliente
export interface Customer {
  id: string;
  name: string;
  cpf: string;
  phone: string;
  address: string;
  email?: string;
  createdAt: number;
  createdBy: string;
}

// Parcela
export interface Installment {
  id: string;
  saleId: string;
  number: number;
  amount: number;
  dueDate: number;
  status: 'pending' | 'paid' | 'overdue';
  paidAt?: number;
  receivedBy?: string;
}

// Entrega
export interface Delivery {
  id: string;
  saleId: string;
  driverId?: string;
  status: 'pending' | 'assigned' | 'in_route' | 'delivered' | 'problem';
  assignedAt?: number;
  deliveredAt?: number;
  notes?: string;
}

// Fechamento Diário
export interface DailyClosing {
  id: string;
  sellerId: string;
  closingDate: number;
  cashAmount: number;
  cardAmount: number;
  pixAmount: number;
  installmentAmount: number;
  salesIds: string[];
  status: 'pending' | 'approved' | 'rejected';
  approvedBy?: string;
  notes?: string;
}

// Sessão do Usuário (mock)
export interface UserSession {
  id: string;
  name: string;
  role: 'gerente' | 'vendedor' | 'entregador' | 'cliente';
  avatar?: string;
}
```

