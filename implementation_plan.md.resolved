```mermaid
flowchart TB
    subgraph Fornecedor
        A[Compra Mensal<br>de Cestas]
    end
    
    subgraph Gerente
        B[Entrada de Estoque]
        C[Dashboard]
        D[Prestação de Contas]
    end
    
    subgraph VendaOnline["Venda Online"]
        E[Cliente acessa App]
        F[Seleciona Modelo]
        G[Pagamento Online]
        H[Aguarda Entrega]
    end
    
    subgraph VendaPresencial["Venda Presencial"]
        I[Vendedor vai até cliente]
        J[Cadastra Cliente]
        K[Seleciona Pagamento]
        L[Baixa Estoque]
        M[Parcelas se A Prazo]
    end
    
    subgraph Entrega
        N[Atribuir Entregador]
        O[GPS Tracking]
        P[Confirmar Entrega]
    end
    
    A --> B
    B --> C
    E --> F --> G --> N
    I --> J --> K --> L
    K --> M
    N --> O --> P
    L --> D
    M --> D
```

